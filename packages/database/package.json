{
	"name": "@monte/database",
	"version": "0.1.0",
	"private": true,
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"typecheck": "bun x tsc --noEmit",
		"lint": "bun x biome check",
		"db:migrate": "bun run scripts/migrate.ts",
		"db:new": "bun run scripts/new-migration.ts",
		"db:codegen": "bun x kysely-codegen --dialect postgres --out-file src/types.ts",
		"test": "bun test"
	},
	"dependencies": {
		"kysely": "^0.28.7",
		"pg": "^8.12.0",
		"dotenv": "^16.4.5"
	},
	"devDependencies": {
		"@types/pg": "^8.15.5",
		"kysely-codegen": "^0.15.0",
		"typescript": "^5"
	}
}
