# Optional Timeback service configuration
# This package is not currently wired into the Monte Math apps, but these
# values are required if you plan to run the client generators or connect to
# the Timeback APIs locally.

# Global defaults
TIMEBACK_ENVIRONMENT=staging
TIMEBACK_SCOPE=

# Shared OAuth client credentials (optional fallbacks per environment)
STAGING_CLIENT_ID=
STAGING_CLIENT_SECRET=
PROD_CLIENT_ID=
PROD_CLIENT_SECRET=

# Token endpoint overrides (leave blank to use service defaults)
TIMEBACK_STAGING_TOKEN_URL=
TIMEBACK_PRODUCTION_TOKEN_URL=

# QTI API endpoints
QTI_STAGING_API_URL=
QTI_PROD_API_URL=

# OneRoster API endpoints
ONEROSTER_STAGING_API_URL=
ONEROSTER_PROD_API_URL=

# Caliper API endpoints
CALIPER_STAGING_API_URL=
CALIPER_PROD_API_URL=

# PowerPath API endpoints
POWERPATH_STAGING_API_URL=
POWERPATH_PROD_API_URL=

# EduBridge API endpoints
EDUBRIDGE_STAGING_API_URL=
EDUBRIDGE_PROD_API_URL=
