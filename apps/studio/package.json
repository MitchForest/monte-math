    "@types/cytoscape": "^3.19.16",
    "@types/node": "^20.14.10",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^3.2.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^27.0.0",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^3.2.4"
  }
