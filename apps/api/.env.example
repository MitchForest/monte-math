# Monte Math API configuration
# Copy this file to .env and fill in values before running the API.

# HTTP server
PORT=3001

# Application URLs used for CORS and link generation
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database connectivity (Supabase Postgres or local Postgres instance)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_SSL_MODE=disable
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Supabase service credentials (required for privileged operations)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional: expose anon key if you need to fan out requests on behalf of the user
SUPABASE_ANON_KEY=

# Logging / diagnostics
LOG_LEVEL=info
