# Server Configuration
PORT=3001
NODE_ENV=development

# Session Configuration
SESSION_COOKIE_NAME=monte_session
SESSION_MAX_AGE_SECONDS=604800
# 7 days in seconds (7 * 24 * 60 * 60)

# Security Secrets (Generate these - see README)
JWT_SECRET=your-jwt-secret-here-min-32-chars
SESSION_SECRET=your-session-secret-here-min-32-chars

# OAuth Providers (Optional - leave empty to disable)
# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth  
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (Optional - defaults to local SQLite)
DATABASE_URL=