{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@monte/shared": ["packages/shared/src"],
      "@monte/content-builder": ["packages/content-builder/src"],
      "@monte/api-client": ["packages/api-client/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}
