{
  "name": "monte-math",
  "version": "0.0.1",
  "private": true,
  "description": "Monte Math - Montessori mathematics education platform",
  "scripts": {
    "dev:web": "pnpm --filter @monte/web dev",
    "dev:api": "pnpm --filter @monte/api dev",
    "dev:studio": "pnpm --filter @monte/studio dev",
    "dev": "pnpm --parallel --filter @monte/api --filter @monte/web --filter @monte/studio run dev",
    "sync:pull": "pnpm --filter @monte/api db:seed",
    "sync:push": "bun tools/export-db-to-content.ts",
    "generate:secrets": "bun run tools/generate-secrets.ts",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint . && pnpm -r lint",
    "lint:fix": "eslint . --fix && pnpm -r lint:fix",
    "format": "prettier --write . && pnpm -r format",
    "format:check": "prettier --check . && pnpm -r format:check",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
